# ===== 데이터베이스 (Postgres — Neon 또는 Supabase 무료 티어) =====
# 예: postgresql://user:pass@host:5432/dbname?sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/webnovel?schema=public"

# ===== NextAuth =====
# openssl rand -base64 32  로 생성
NEXTAUTH_SECRET="change-me-to-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# ===== Discord OAuth (Developer Portal > OAuth2) =====
# Redirect URI 등록: http://localhost:3000/api/auth/callback/discord
#                    https://<배포도메인>/api/auth/callback/discord
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""

# ===== 최초 관리자 =====
# 본인 Discord 유저 ID(snowflake). 이 ID로 로그인하면 자동 ADMIN 부여.
ADMIN_DISCORD_ID=""

# ===== (STEP2 이후) 이미지 스토리지 — Supabase Storage =====
# NEXT_PUBLIC_SUPABASE_URL=""
# SUPABASE_SERVICE_ROLE_KEY=""
# SUPABASE_STORAGE_BUCKET="uploads"

# ===== (보안 STEP) Rate limit — Upstash Redis (선택) =====
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""
